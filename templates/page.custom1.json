          "type": "ai_gen_block_26d1f95",
          "settings": {
            "heading": "Why we are called 5DLA",
            "heading_color": "#222222",
            "heading_size": 48,
            "heading_weight": "700",
            "heading_spacing": 20,
            "paragraph_text": "<p>5DLA comes from the Cantonese phrase:<br/><br/><strong>「快啲啦」</strong><br/><br/>It means \"quicker.\"<br/>But for us, it has a deeper meaning.<br/>It is not about being quicker than others.<br/>It is about being quicker than who you were yesterday.<br/><br/>Making decisions faster.<br/>Taking action sooner.<br/>Improving, day by day.<br/><br/>Endurance sport is built on consistency.<br/>Small gains, repeated over time.<br/><br/>5DLA is a reminder of that mindset.</p>",
            "desktop_width_percent": 100,
