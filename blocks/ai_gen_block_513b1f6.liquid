{% doc %}
  @prompt
    Add an email sign-up box to the Community section. It should include a heading like "Join Our Community", a short description, an email input field, and a submit button. Style it to match the existing section's design aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-community-signup-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-community-signup__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-community-signup__description-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.description_spacing }}px;
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
  }

  .ai-community-signup__form-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.form_max_width }}px;
    margin: 0 auto;
  }

  .ai-community-signup__field-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.field_gap }}px;
    flex-wrap: wrap;
  }

  .ai-community-signup__input-{{ ai_gen_id }} {
    flex: 1 1 200px;
    padding: {{ block.settings.input_padding }}px 16px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: {{ block.settings.input_font_size }}px;
    color: {{ block.settings.input_text_color }};
    background-color: {{ block.settings.input_background_color }};
    transition: border-color 0.3s ease;
  }

  .ai-community-signup__input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
  }

  .ai-community-signup__input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_placeholder_color }};
  }

  .ai-community-signup__button-{{ ai_gen_id }} {
    flex: 0 0 auto;
    padding: {{ block.settings.input_padding }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-community-signup__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    transform: translateY(-2px);
  }

  .ai-community-signup__success-{{ ai_gen_id }} {
    margin-top: 12px;
    padding: 12px;
    background-color: {{ block.settings.success_bg_color }};
    color: {{ block.settings.success_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
  }

  .ai-community-signup__error-{{ ai_gen_id }} {
    margin-top: 12px;
    padding: 12px;
    background-color: {{ block.settings.error_bg_color }};
    color: {{ block.settings.error_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-community-signup__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-community-signup__description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }

    .ai-community-signup__field-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-community-signup__input-{{ ai_gen_id }},
    .ai-community-signup__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div
  class="ai-community-signup-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {%- form 'customer', class: 'ai-community-signup__form-wrapper-' | append: ai_gen_id -%}
    <input
      type="hidden"
      name="contact[tags]"
      value="newsletter"
    >

    {%- if block.settings.heading != blank -%}
      <h2 class="ai-community-signup__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {%- endif -%}

    {%- if block.settings.description != blank -%}
      <div class="ai-community-signup__description-{{ ai_gen_id }}">
        {{ block.settings.description }}
      </div>
    {%- endif -%}

    <div class="ai-community-signup__field-{{ ai_gen_id }}">
      <input
        type="email"
        name="contact[email]"
        class="ai-community-signup__input-{{ ai_gen_id }}"
        value="{{ form.email }}"
        aria-required="true"
        autocorrect="off"
        autocapitalize="off"
        autocomplete="email"
        {% if form.errors %}
          aria-invalid="true"
          aria-describedby="ai-community-signup-error-{{ ai_gen_id }}"
        {% endif %}
        {% if form.posted_successfully? %}
          aria-describedby="ai-community-signup-success-{{ ai_gen_id }}"
        {% endif %}
        placeholder="{{ block.settings.email_placeholder }}"
        required
      >
      <button
        type="submit"
        class="ai-community-signup__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </button>
    </div>

    {%- if form.errors -%}
      <div
        id="ai-community-signup-error-{{ ai_gen_id }}"
        class="ai-community-signup__error-{{ ai_gen_id }}"
      >
        {{ form.errors.messages.email }}
      </div>
    {%- endif -%}

    {%- if form.posted_successfully? -%}
      <div
        id="ai-community-signup-success-{{ ai_gen_id }}"
        class="ai-community-signup__success-{{ ai_gen_id }}"
      >
        {{ block.settings.success_message }}
      </div>
    {%- endif -%}
  {%- endform -%}
</div>

