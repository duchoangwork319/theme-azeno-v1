{% doc %}
  @prompt
    Regenerate the current AI-generated block layout so it has 5 text boxes arranged in a 3-on-top, 2-on-bottom grid layout. The top row should have 3 equal-width text boxes side by side, and the bottom row should have 2 equal-width text boxes centered or evenly spaced. Keep the existing content and styling consistent with the rest of the block.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-text-grid__container-{{ ai_gen_id }} {
    display: grid;
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-text-grid__row-{{ ai_gen_id }} {
    display: grid;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-text-grid__row-top-{{ ai_gen_id }} {
    grid-template-columns: repeat(3, 1fr);
  }

  .ai-text-grid__row-bottom-{{ ai_gen_id }} {
    grid-template-columns: repeat(2, 1fr);
  }

  .ai-text-grid__box-{{ ai_gen_id }} {
    background-color: {{ block.settings.box_bg_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.box_padding }}px;
    text-align: {{ block.settings.text_align }};
    transition: all 0.3s ease;
  }

  .ai-text-grid__box-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.box_hover_bg_color }};
    border-color: {{ block.settings.border_hover_color }};
    transform: translateY(-{{ block.settings.hover_lift }}px);
  }

  .ai-text-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    font-weight: 600;
  }

  .ai-text-grid__box-{{ ai_gen_id }}:hover .ai-text-grid__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_hover_color }};
  }

  .ai-text-grid__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-text-grid__box-{{ ai_gen_id }}:hover .ai-text-grid__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_hover_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-text-grid__row-top-{{ ai_gen_id }},
    .ai-text-grid__row-bottom-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-text-grid__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-text-grid__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-text-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-grid__container-{{ ai_gen_id }}">
    <div class="ai-text-grid__row-{{ ai_gen_id }} ai-text-grid__row-top-{{ ai_gen_id }}">
      <div class="ai-text-grid__box-{{ ai_gen_id }}">
        {% if block.settings.box_1_title != blank %}
          <h3 class="ai-text-grid__title-{{ ai_gen_id }}">{{ block.settings.box_1_title }}</h3>
        {% endif %}
        {% if block.settings.box_1_text != blank %}
          <div class="ai-text-grid__text-{{ ai_gen_id }}">{{ block.settings.box_1_text }}</div>
        {% endif %}
      </div>

      <div class="ai-text-grid__box-{{ ai_gen_id }}">
        {% if block.settings.box_2_title != blank %}
          <h3 class="ai-text-grid__title-{{ ai_gen_id }}">{{ block.settings.box_2_title }}</h3>
        {% endif %}
        {% if block.settings.box_2_text != blank %}
          <div class="ai-text-grid__text-{{ ai_gen_id }}">{{ block.settings.box_2_text }}</div>
        {% endif %}
      </div>

      <div class="ai-text-grid__box-{{ ai_gen_id }}">
        {% if block.settings.box_3_title != blank %}
          <h3 class="ai-text-grid__title-{{ ai_gen_id }}">{{ block.settings.box_3_title }}</h3>
        {% endif %}
        {% if block.settings.box_3_text != blank %}
          <div class="ai-text-grid__text-{{ ai_gen_id }}">{{ block.settings.box_3_text }}</div>
        {% endif %}
      </div>
    </div>

    <div class="ai-text-grid__row-{{ ai_gen_id }} ai-text-grid__row-bottom-{{ ai_gen_id }}">
      <div class="ai-text-grid__box-{{ ai_gen_id }}">
        {% if block.settings.box_4_title != blank %}
          <h3 class="ai-text-grid__title-{{ ai_gen_id }}">{{ block.settings.box_4_title }}</h3>
        {% endif %}
        {% if block.settings.box_4_text != blank %}
          <div class="ai-text-grid__text-{{ ai_gen_id }}">{{ block.settings.box_4_text }}</div>
        {% endif %}
      </div>

      <div class="ai-text-grid__box-{{ ai_gen_id }}">
        {% if block.settings.box_5_title != blank %}
          <h3 class="ai-text-grid__title-{{ ai_gen_id }}">{{ block.settings.box_5_title }}</h3>
        {% endif %}
        {% if block.settings.box_5_text != blank %}
          <div class="ai-text-grid__text-{{ ai_gen_id }}">{{ block.settings.box_5_text }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

