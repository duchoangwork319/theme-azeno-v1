{% doc %}
  @prompt
    add a section with this text 
    
    Title: The Brands We Carry
    
    paragraph: We partner with brands that share the same performance-first mindset.
    
    FUSION
    
    Official Partner in Asia-Pacific
    Premium endurance apparel engineered for reliability, function, and race-day performance.
    
    (Logo placement here)
    
    More brands will be added over time, but the principle remains the same.
    
    Quality first. Always.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brands-showcase-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    text-align: center;
  }

  .ai-brands-showcase__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-brands-showcase__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: 600;
  }

  .ai-brands-showcase__intro-{{ ai_gen_id }} {
    font-size: {{ block.settings.intro_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.intro_spacing }}px;
    line-height: 1.6;
  }

  .ai-brands-showcase__brand-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    margin: {{ block.settings.card_spacing }}px 0;
  }

  .ai-brands-showcase__brand-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.brand_name_size }}px;
    color: {{ block.settings.brand_name_color }};
    margin: 0 0 {{ block.settings.brand_name_spacing }}px;
    font-weight: 700;
    letter-spacing: 2px;
  }

  .ai-brands-showcase__brand-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.brand_subtitle_size }}px;
    color: {{ block.settings.brand_subtitle_color }};
    margin: 0 0 {{ block.settings.brand_subtitle_spacing }}px;
    font-weight: 600;
  }

  .ai-brands-showcase__brand-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.brand_desc_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.brand_desc_spacing }}px;
    line-height: 1.6;
  }

  .ai-brands-showcase__logo-container-{{ ai_gen_id }} {
    margin: {{ block.settings.logo_spacing }}px 0;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100px;
  }

  .ai-brands-showcase__logo-{{ ai_gen_id }} {
    max-width: {{ block.settings.logo_max_width }}px;
    height: auto;
    display: block;
  }

  .ai-brands-showcase__logo-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    border-radius: 8px;
    padding: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 200px;
  }

  .ai-brands-showcase__logo-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-brands-showcase__footer-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.footer_text_size }}px;
    color: {{ block.settings.text_color }};
    margin: {{ block.settings.footer_spacing }}px 0 0;
    line-height: 1.8;
  }

  .ai-brands-showcase__footer-highlight-{{ ai_gen_id }} {
    font-weight: 700;
    color: {{ block.settings.highlight_color }};
    display: block;
    margin-top: 15px;
  }

  @media screen and (max-width: 749px) {
    .ai-brands-showcase-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.section_padding | times: 0.6 }}px 15px;
    }

    .ai-brands-showcase__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-brands-showcase__brand-name-{{ ai_gen_id }} {
      font-size: {{ block.settings.brand_name_size | times: 0.8 }}px;
    }

    .ai-brands-showcase__logo-{{ ai_gen_id }} {
      max-width: {{ block.settings.logo_max_width | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-brands-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brands-showcase__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-brands-showcase__title-{{ ai_gen_id }}">
        {{ block.settings.title }}
      </h2>
    {% endif %}

    {% if block.settings.intro_text != blank %}
      <p class="ai-brands-showcase__intro-{{ ai_gen_id }}">
        {{ block.settings.intro_text }}
      </p>
    {% endif %}

    <div class="ai-brands-showcase__brand-card-{{ ai_gen_id }}">
      {% if block.settings.brand_name != blank %}
        <h3 class="ai-brands-showcase__brand-name-{{ ai_gen_id }}">
          {{ block.settings.brand_name }}
        </h3>
      {% endif %}

      {% if block.settings.brand_subtitle != blank %}
        <p class="ai-brands-showcase__brand-subtitle-{{ ai_gen_id }}">
          {{ block.settings.brand_subtitle }}
        </p>
      {% endif %}

      {% if block.settings.brand_description != blank %}
        <p class="ai-brands-showcase__brand-description-{{ ai_gen_id }}">
          {{ block.settings.brand_description }}
        </p>
      {% endif %}

      <div class="ai-brands-showcase__logo-container-{{ ai_gen_id }}">
        {% if block.settings.brand_logo %}
          <img
            src="{{ block.settings.brand_logo | image_url: width: 600 }}"
            alt="{{ block.settings.brand_name | escape }}"
            class="ai-brands-showcase__logo-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.brand_logo.width }}"
            height="{{ block.settings.brand_logo.height }}"
          >
        {% else %}
          <div class="ai-brands-showcase__logo-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    {% if block.settings.footer_text != blank %}
      <div class="ai-brands-showcase__footer-text-{{ ai_gen_id }}">
        {{ block.settings.footer_text }}
        {% if block.settings.footer_highlight != blank %}
          <span class="ai-brands-showcase__footer-highlight-{{ ai_gen_id }}">
            {{ block.settings.footer_highlight }}
          </span>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

