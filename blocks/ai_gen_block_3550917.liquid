{% doc %}
  @prompt
    add shop category CTA
    Shop Men
    Shoe Women
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-category-cta-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-category-cta__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.button_gap }}px;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
    flex-wrap: wrap;
  }

  .ai-category-cta__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    text-transform: {{ block.settings.button_text_transform }};
    cursor: pointer;
    transition: all 0.3s ease;
    min-width: {{ block.settings.button_min_width }}px;
  }

  .ai-category-cta__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
    border-color: {{ block.settings.button_border_hover_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-category-cta__container-{{ ai_gen_id }} {
      flex-direction: column;
      width: 100%;
    }

    .ai-category-cta__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-category-cta-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-category-cta__container-{{ ai_gen_id }}">
    {% if block.settings.show_men_button %}
      <a
        href="{{ block.settings.men_link }}"
        class="ai-category-cta__button-{{ ai_gen_id }}"
      >
        {{ block.settings.men_button_text }}
      </a>
    {% endif %}

    {% if block.settings.show_women_button %}
      <a
        href="{{ block.settings.women_link }}"
        class="ai-category-cta__button-{{ ai_gen_id }}"
      >
        {{ block.settings.women_button_text }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Shop category CTA",
  "settings": [
    {
      "type": "header",
      "content": "Men category"
    },
    {
      "type": "checkbox",
      "id": "show_men_button",
      "label": "Show men button",
      "default": true
    },
    {
      "type": "text",
      "id": "men_button_text",
      "label": "Button text",
      "default": "Shop Men"
    },
    {
      "type": "url",
      "id": "men_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Women category"
    },
    {
      "type": "checkbox",
      "id": "show_women_button",
      "label": "Show women button",
      "default": true
    },
    {
      "type": "text",
      "id": "women_button_text",
      "label": "Button text",
      "default": "Shop Women"
    },
    {
      "type": "url",
      "id": "women_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "button_gap",
      "label": "Gap between buttons",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Vertical padding",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Horizontal padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "button_min_width",
      "label": "Minimum width",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 200
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "button_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "button_text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Border width",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "header",
      "content": "Button colors"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "button_bg_hover_color",
      "label": "Hover background",
      "default": "#ff3535"
    },
    {
      "type": "color",
      "id": "button_text_hover_color",
      "label": "Hover text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border_hover_color",
      "label": "Hover border",
      "default": "#ff3535"
    }
  ],
  "presets": [
    {
      "name": "Shop category CTA"
    }
  ]
}
{% endschema %}
