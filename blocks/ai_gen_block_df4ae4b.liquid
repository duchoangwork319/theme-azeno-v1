{% doc %}
  @prompt
    Recreate the "Text overlay with image" block on the brands page with full mobile responsiveness. The block should display an image with text overlaid on top. Requirements: text must never be cropped or overflow on any screen size, text wraps properly on mobile, font sizes scale down responsively using clamp() or media queries, the image scales correctly on mobile without cutting off, overlay padding adjusts for small screens, and all content remains fully readable on devices as small as 320px wide.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-overlay-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
    overflow: hidden;
  }

  .ai-text-overlay-container-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-text-overlay-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
    background-color: {{ block.settings.image_bg_color }};
  }

  .ai-text-overlay-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-text-overlay-placeholder-{{ ai_gen_id }} {
    width: 100%;
    min-height: 400px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-text-overlay-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-text-overlay-content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.vertical_alignment }};
    align-items: {{ block.settings.horizontal_alignment }};
    padding: clamp(20px, 5vw, {{ block.settings.overlay_padding }}px);
    text-align: {{ block.settings.text_alignment }};
    z-index: 2;
  }

  .ai-text-overlay-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  .ai-text-overlay-text-wrapper-{{ ai_gen_id }} {
    max-width: 100%;
    width: 100%;
    word-wrap: break-word;
    overflow-wrap: break-word;
    hyphens: auto;
  }

  .ai-text-overlay-heading-{{ ai_gen_id }} {
    font-size: clamp({{ block.settings.heading_size_mobile }}px, {{ block.settings.heading_size_tablet }}vw, {{ block.settings.heading_size }}px);
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 clamp(10px, 2vw, 20px) 0;
    line-height: 1.2;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .ai-text-overlay-subheading-{{ ai_gen_id }} {
    font-size: clamp({{ block.settings.subheading_size_mobile }}px, {{ block.settings.subheading_size_tablet }}vw, {{ block.settings.subheading_size }}px);
    font-weight: {{ block.settings.subheading_weight }};
    color: {{ block.settings.subheading_color }};
    margin: 0 0 clamp(15px, 3vw, 25px) 0;
    line-height: 1.4;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .ai-text-overlay-description-{{ ai_gen_id }} {
    font-size: clamp({{ block.settings.description_size_mobile }}px, {{ block.settings.description_size_tablet }}vw, {{ block.settings.description_size }}px);
    color: {{ block.settings.description_color }};
    margin: 0 0 clamp(15px, 3vw, 25px) 0;
    line-height: 1.6;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .ai-text-overlay-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: clamp(10px, 2vw, {{ block.settings.button_padding_vertical }}px) clamp(20px, 4vw, {{ block.settings.button_padding_horizontal }}px);
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: clamp({{ block.settings.button_size_mobile }}px, {{ block.settings.button_size_tablet }}vw, {{ block.settings.button_size }}px);
    font-weight: {{ block.settings.button_weight }};
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .ai-text-overlay-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-text-overlay-container-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-text-overlay-placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-text-overlay-content-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-text-overlay-button-{{ ai_gen_id }} {
      white-space: normal;
      word-wrap: break-word;
    }
  }

  @media screen and (max-width: 320px) {
    .ai-text-overlay-content-{{ ai_gen_id }} {
      padding: 15px;
    }

    .ai-text-overlay-heading-{{ ai_gen_id }},
    .ai-text-overlay-subheading-{{ ai_gen_id }},
    .ai-text-overlay-description-{{ ai_gen_id }} {
      word-break: break-word;
    }
  }
{% endstyle %}

<div class="ai-text-overlay-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-overlay-container-{{ ai_gen_id }}">
    <div class="ai-text-overlay-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-text-overlay-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-text-overlay-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}

      {% if block.settings.show_overlay %}
        <div class="ai-text-overlay-overlay-{{ ai_gen_id }}"></div>
      {% endif %}

      <div class="ai-text-overlay-content-{{ ai_gen_id }}">
        <div class="ai-text-overlay-text-wrapper-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-text-overlay-heading-{{ ai_gen_id }}">
              {{ block.settings.heading }}
            </h2>
          {% endif %}

          {% if block.settings.subheading != blank %}
            <h3 class="ai-text-overlay-subheading-{{ ai_gen_id }}">
              {{ block.settings.subheading }}
            </h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <div class="ai-text-overlay-description-{{ ai_gen_id }}">
              {{ block.settings.description }}
            </div>
          {% endif %}

          {% if block.settings.button_text != blank %}
            <a
              href="{{ block.settings.button_link }}"
              class="ai-text-overlay-button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

