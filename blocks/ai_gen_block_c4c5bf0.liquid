{% doc %}
  @prompt
    5 text boxes horizontally  with headline for each
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-boxes-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-text-boxes-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    justify-content: space-between;
    align-items: flex-start;
  }

  .ai-text-box-{{ ai_gen_id }} {
    flex: 1;
    text-align: {{ block.settings.text_alignment }};
    padding: {{ block.settings.box_padding }}px;
    background-color: {{ block.settings.box_background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-text-box-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.headline_spacing }}px 0;
    font-weight: {{ block.settings.headline_weight }};
  }

  .ai-text-box-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.content_size }}px;
    color: {{ block.settings.content_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .ai-text-boxes-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-text-box-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-text-boxes-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-boxes-container-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign headline_key = 'headline_' | append: i
        assign content_key = 'content_' | append: i
        assign headline = block.settings[headline_key]
        assign content = block.settings[content_key]
      %}
      
      <div class="ai-text-box-{{ ai_gen_id }}">
        {% if headline != blank %}
          <h3 class="ai-text-box-headline-{{ ai_gen_id }}">{{ headline }}</h3>
        {% endif %}
        {% if content != blank %}
          <div class="ai-text-box-content-{{ ai_gen_id }}">{{ content }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

